<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>BGTaskSchedulerPermittedIdentifiers</key>
	<array>
		<string>com.veu.protocol.sync.refresh</string>
		<string>com.veu.protocol.sync.processing</string>
	</array>
	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>
	<key>CFBundleDisplayName</key>
	<string>Veu</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>NSBonjourServices</key>
	<array>
		<string>_veu-ghost._tcp</string>
		<string>_veu-handshake._tcp</string>
		<string>_veu-handshake._udp</string>
		<string>_veu-mesh._tcp</string>
	</array>
	<key>NSCameraUsageDescription</key>
	<string>Veu needs camera access to capture photos for encrypted sharing.</string>
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>Veu saves images to your photo library when you choose to download them.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>Veu needs microphone access for encrypted voice calls.</string>
	<key>NSFaceIDUsageDescription</key>
	<string>Veu uses Face ID to authenticate before revealing protected content.</string>
	<key>NSLocalNetworkUsageDescription</key>
	<string>Veu discovers nearby devices for secure handshakes and encrypted artifact sync.</string>
	<key>NSNearbyInteractionUsageDescription</key>
	<string>Veu uses Ultra Wideband to verify the other device is physically nearby during the handshake.</string>
	<key>UIBackgroundModes</key>
	<array>
		<string>audio</string>
		<string>fetch</string>
		<string>processing</string>
		<string>remote-notification</string>
		<string>voip</string>
	</array>
	<key>UILaunchScreen</key>
	<dict>
		<key>UIColorName</key>
		<string>AccentColor</string>
	</dict>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>CFBundleIconName</key>
	<string>AppIcon</string>
</dict>
</plist>
